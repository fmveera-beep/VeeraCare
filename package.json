{
  "name": "veeracare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "clean": "rimraf .next node_modules/.cache",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "postinstall": "prisma generate",
    "neon:auth-webhook": "node scripts/configure-neon-auth-webhook.mjs",
    "neon:auth-smtp": "node scripts/configure-neon-auth-smtp.mjs --provider resend",
    "neon:auth-smtp:test": "node scripts/configure-neon-auth-smtp.mjs --provider resend --test admin@veerafm.com",
    "neon:auth-smtp:resend": "node scripts/configure-neon-auth-smtp.mjs --provider resend --test admin@veerafm.com",
    "neon:auth-smtp:m365": "node scripts/configure-neon-auth-smtp.mjs --provider m365 --test admin@veerafm.com",
    "neon:auth-smtp:gmail": "node scripts/configure-neon-auth-smtp.mjs --provider gmail --test admin@veerafm.com",
    "test:graph": "node scripts/test-graph.mjs admin@veerafm.com",
    "test:smtp:m365": "node scripts/test-smtp.mjs m365 admin@veerafm.com",
    "test:smtp:gmail": "node scripts/test-smtp.mjs gmail admin@veerafm.com"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.0-beta",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/blob": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.35",
    "nodemailer": "^6.9.14",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
