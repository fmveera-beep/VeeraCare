generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum ServiceNeeded {
  HOUSEMAID
  HOUSE_CLEANER
  TECHNICIAN
  CONSTRUCTION
  EVENT
  SECURITY_PERSONNEL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StaffRequest {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String
  serviceNeeded ServiceNeeded
  message       String
  sourcePath    String?
  createdAt     DateTime      @default(now())

  @@index([createdAt])
  @@index([serviceNeeded])
  @@index([email])
}
