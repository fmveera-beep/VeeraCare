generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum PortalAccountType {
  WORKER
  EMPLOYER
}

enum ServiceNeeded {
  HOUSEMAID
  HOUSE_CLEANER
  TECHNICIAN
  CONSTRUCTION
  EVENT
  SECURITY_PERSONNEL
}

enum CtaInquiryType {
  HIRING
  WORKER
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  name               String?
  phone              String?
  portalAccountType  PortalAccountType @default(EMPLOYER)
  role               Role              @default(CLIENT)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model StaffRequest {
  id             String          @id @default(cuid())
  inquiryType    CtaInquiryType  @default(HIRING)
  name           String
  phone          String
  email          String
  serviceNeeded  ServiceNeeded
  availability   String?
  message        String
  sourcePath     String?
  createdAt      DateTime        @default(now())

  @@index([createdAt])
  @@index([serviceNeeded])
  @@index([email])
  @@index([inquiryType])
}
