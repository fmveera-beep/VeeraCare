DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
JWT_SECRET="replace-with-a-long-random-string-at-least-16-chars"

# Set to true only if remote landing images still fail (uses plain <img>, larger payloads).
# DISABLE_IMAGE_OPTIMIZATION=true

NEXT_PUBLIC_CAREERS_EMAIL="hello@veeracare.com"
NEXT_PUBLIC_INTRO_VIDEO_EMBED="https://www.youtube-nocookie.com/embed/M7lc1UVf-VE"

# Optional landing imagery. Leave unset or use a full URL — empty values are ignored.
# Default hero uses bundled src/assets/hero-main.png when NEXT_PUBLIC_HERO_IMAGE_MAIN is unset.
# NEXT_PUBLIC_HERO_IMAGE_MAIN=
# NEXT_PUBLIC_HERO_IMAGE_INSET=
# NEXT_PUBLIC_ABOUT_PORTRAIT=
# NEXT_PUBLIC_ABOUT_SERVER=
# NEXT_PUBLIC_DEI_IMAGE=
# NEXT_PUBLIC_VIDEO_THUMB=
# NEXT_PUBLIC_CAREER_IMAGE=
# NEXT_PUBLIC_REVIEW_AVATAR_1=
