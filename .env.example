# Copy this file to `.env` and fill in values.

# --- Database ---
# Prisma Postgres connection string (Neon recommended).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# --- Auth / app secrets ---
# Any long random string (16+ chars). Keep private.
JWT_SECRET="replace-with-a-long-random-secret"

# --- Email notifications (optional) ---
# Where CTA leads get delivered (fallbacks exist, but set this).
OWNER_NOTIFY_EMAIL="hello@veeracare.com"

# SMTP settings (used by Nodemailer in src/lib/email/cta.ts)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="you@gmail.com"
# For Gmail, use a Google **App Password** (requires 2-Step Verification).
SMTP_PASS="replace-with-app-password"
SMTP_FROM="VeeraCare <you@gmail.com>"

# Legacy / optional override for recipient inbox
CTA_NOTIFY_TO=""

# --- Images / media (optional) ---
# Disable Next image optimization (useful for some Windows/dev setups).
DISABLE_IMAGE_OPTIMIZATION="false"

# Public site config (optional overrides)
NEXT_PUBLIC_CAREERS_EMAIL="hello@veeracare.com"
NEXT_PUBLIC_INTRO_VIDEO_EMBED="https://www.youtube-nocookie.com/embed/M7lc1UVf-VE"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/"
NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://www.instagram.com/"
NEXT_PUBLIC_SOCIAL_LINKEDIN="https://www.linkedin.com/"
NEXT_PUBLIC_SOCIAL_X="https://twitter.com/"
NEXT_PUBLIC_SOCIAL_YOUTUBE="https://www.youtube.com/"

# Optional image URL overrides (leave blank to use defaults)
NEXT_PUBLIC_HERO_IMAGE_MAIN=""
NEXT_PUBLIC_HERO_IMAGE_INSET=""
NEXT_PUBLIC_ABOUT_PORTRAIT=""
NEXT_PUBLIC_ABOUT_SERVER=""
NEXT_PUBLIC_DEI_IMAGE=""
NEXT_PUBLIC_VIDEO_THUMB=""
NEXT_PUBLIC_CAREER_IMAGE=""
NEXT_PUBLIC_REVIEW_AVATAR_1=""
NEXT_PUBLIC_REVIEW_AVATAR_2=""

