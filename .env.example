# Copy this file to `.env` and fill in values.

# --- Database ---
# Prisma Postgres connection string (Neon recommended).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# --- Neon Auth (CMS admin login — Email OTP) ---
# From Neon Console: Project → Branch → Auth → Configuration (copy Auth URL).
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.region.aws.neon.tech/neondb/auth"
# 32+ chars; openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="replace-with-a-random-secret-at-least-32-characters-long"
# Optional extra admins (merged with SOURCE_ADMIN_EMAILS in src/lib/neon-auth/adminEmails.ts).
ADMIN_EMAIL=""
# Optional: same list so the login page can hint / validate before sending OTP.
NEXT_PUBLIC_ADMIN_EMAIL="admin@veeracare.com, backup-admin@veeracare.com"

# --- CTA / contact form email ---
#
# Two separate settings:
#   • OWNER_NOTIFY_EMAIL  → WHERE leads are delivered (use the client's Outlook inbox)
#   • SMTP_*              → HOW mail is sent (Gmail or Outlook — either is fine)
#
# Example: send via Gmail SMTP, deliver to Outlook:
#   OWNER_NOTIFY_EMAIL="contact@clientcompany.com"   # Microsoft 365 / Outlook inbox
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_USER="notifications@gmail.com"
#
# Example: send and receive both on Outlook:
#   OWNER_NOTIFY_EMAIL="contact@clientcompany.com"
#   SMTP_HOST="smtp.office365.com"
#   SMTP_USER="contact@clientcompany.com"

# Required: client Outlook inbox for all hiring/worker form notifications
OWNER_NOTIFY_EMAIL="contact@clientcompany.com"

# --- SMTP (sender) — Gmail OR Microsoft 365 / Outlook ---
# Gmail:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="you@gmail.com"
SMTP_PASS="replace-with-gmail-app-password"
SMTP_FROM="VeeraCare <you@gmail.com>"
# Microsoft 365 (uncomment and use instead of Gmail if the client sends from Outlook):
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT=587
# SMTP_USER="contact@clientcompany.com"
# SMTP_PASS="replace-with-password-or-app-password"
# SMTP_FROM="VeeraCare <contact@clientcompany.com>"

# Optional alias for OWNER_NOTIFY_EMAIL (same inbox)
CTA_NOTIFY_TO=""

# --- Images / media (optional) ---
# Disable Next image optimization (useful for some Windows/dev setups).
DISABLE_IMAGE_OPTIMIZATION="false"

# Public site config (optional overrides)
NEXT_PUBLIC_CAREERS_EMAIL="admin@veeracare.com"
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY="+971 55 572 2868"
NEXT_PUBLIC_CONTACT_PHONE_E164="971555722868"
NEXT_PUBLIC_INTRO_VIDEO_EMBED="https://www.youtube-nocookie.com/embed/M7lc1UVf-VE"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://www.facebook.com/"
NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://www.instagram.com/"
NEXT_PUBLIC_SOCIAL_LINKEDIN="https://www.linkedin.com/"
NEXT_PUBLIC_SOCIAL_X="https://twitter.com/"
NEXT_PUBLIC_SOCIAL_YOUTUBE="https://www.youtube.com/"

# Optional image URL overrides (leave blank to use defaults)
NEXT_PUBLIC_HERO_IMAGE_MAIN=""
NEXT_PUBLIC_HERO_IMAGE_INSET=""
NEXT_PUBLIC_ABOUT_PORTRAIT=""
NEXT_PUBLIC_ABOUT_SERVER=""
NEXT_PUBLIC_DEI_IMAGE=""
NEXT_PUBLIC_VIDEO_THUMB=""
NEXT_PUBLIC_CAREER_IMAGE=""
NEXT_PUBLIC_REVIEW_AVATAR_1=""
NEXT_PUBLIC_REVIEW_AVATAR_2=""
